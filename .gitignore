# Secrets and credentials — never commit these
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/

# Generated outputs (not templates)
output/
generated/

# VS Code local settings
.vscode/launch.json
.vscode/*.code-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Templates — ignore binary/user content; track code templates and folder structure
# Binary files (Office docs, PDFs) stay local only — too large and user-specific for git
# Code templates (.html, .tf, .yml) and .gitkeep files ARE tracked
templates/**/*.pdf
templates/**/*.doc
templates/**/*.docx
templates/**/*.xlsx
templates/**/*.xls
templates/**/*.pptx
templates/**/*.ppt
