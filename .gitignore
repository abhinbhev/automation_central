# Secrets and credentials — never commit these
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/

# Generated outputs (not templates)
output/
generated/

# VS Code local settings
.vscode/launch.json
.vscode/*.code-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Templates — binary and user-specific files are local only
# Folder structure is preserved via .gitkeep files
templates/**
!templates/**/
!templates/**/.gitkeep

# Template content files (binary/proprietary — keep folder structure via .gitkeep)
# Code templates (.html, .tf, .yml, .json, .md) are tracked; binary content is not
templates/**/*.pdf
templates/**/*.doc
templates/**/*.docx
templates/**/*.xlsx
templates/**/*.xls
templates/**/*.pptx
templates/**/*.ppt
!templates/**/.gitkeep
